# Anthropic Configuration (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Database — choose ONE (uncomment your option; the other must stay commented)

# Option A — Supabase (Project → Connect → Direct connection)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Option B — local PostgreSQL
# DATABASE_URL=postgresql://root:password@localhost:5432/dbname